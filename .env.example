# Copie para `.env` na raiz (não commitar).
# Use URL completa com https://. No GitHub Actions o secret RECADOS_API_URL pode omitir o https://.

VITE_RECADOS_API_URL=
VITE_TURNSTILE_SITE_KEY=

# URL pública do site (https://…), usada no build para gerar sitemap.xml com <image:image>.
# Alternativa: VITE_SITE_URL=… (lido pelo mesmo script) ou SITE_ORIGIN em src/data/constants.js.
# No GitHub Actions: secret SITE_URL (mesmo valor da URL canônica no Search Console).
SITE_URL=
