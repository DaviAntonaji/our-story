# Copie para `api/.env` localmente (não commitar).

NODE_ENV=production
PORT=7000
TRUST_PROXY=1

TURNSTILE_SECRET_KEY=

MAIL_SERVER=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=

MAIL_FROM=
MAIL_TO=

ALLOWED_ORIGINS=

# --- Banco de dados MySQL 5.7 (opcional — sem isso só o e-mail funciona) ---
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=ourstory

# --- Privacidade: hash HMAC-SHA256 do IP (recomendado, mas opcional) ---
# Gere com: openssl rand -hex 32
# IP_HASH_SECRET=
